<aside class="w-64 bg-[#11162d] border-r border-[#1e2646] flex flex-col justify-between p-4">
  <div class="space-y-8">
    <div class="flex items-center space-x-3 px-2 py-4">
      <%= image_tag "image-cadastro.png", class: "h-14 w-14 rounded-full object-cover", alt: "Lore Cards" %>
      <span class="text-white font-bold text-2xl tracking-wide">Lore Card</span>
    </div>

      <nav class="space-y-1">

        <% if current_user.master? %>

          <%# Cartas %>
          <%= link_to cards_path, class: "flex items-center space-x-3 px-4 py-3 rounded-lg #{controller_name == 'cards' ? 'bg-[#1e2548] text-white' : 'text-slate-400 hover:bg-[#161c3a] hover:text-white'} font-medium text-sm transition-colors" do %>
            <svg class="w-5 h-5 <%= controller_name == 'cards' ? 'text-violet-400' : '' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6M9 11h6M9 15h4" />
            </svg>
            <span>Cartas</span>
          <% end %>

          <%# Coleções %>
          <%= link_to collections_path, class: "flex items-center space-x-3 px-4 py-3 rounded-lg #{controller_name == 'collections' ? 'bg-[#1e2548] text-white' : 'text-slate-400 hover:bg-[#161c3a] hover:text-white'} font-medium text-sm transition-colors" do %>
            <svg class="w-5 h-5 <%= controller_name == 'collections' ? 'text-violet-400' : '' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v10M12 5v14M16 8v9" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 21h14" />
            </svg>
            <span>Coleções</span>
          <% end %>

          <%# Campanhas %>
          <%= link_to campaigns_path, class: "flex items-center space-x-3 px-4 py-3 rounded-lg #{controller_name == 'campaigns' ? 'bg-[#1e2548] text-white' : 'text-slate-400 hover:bg-[#161c3a] hover:text-white'} font-medium text-sm transition-colors" do %>
            <svg class="w-5 h-5 <%= controller_name == 'campaigns' ? 'text-violet-400' : '' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            <span>Campanhas</span>
          <% end %>

        <% else %>

          <%# Minhas Aventuras %>
          <%= link_to player_campaigns_path, class: "flex items-center space-x-3 px-4 py-3 rounded-lg #{controller_name == 'player_campaigns' ? 'bg-[#1e2548] text-white' : 'text-slate-400 hover:bg-[#161c3a] hover:text-white'} font-medium text-sm transition-colors" do %>
            <svg class="w-5 h-5 <%= controller_name == 'player_campaigns' ? 'text-violet-400' : '' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            <span>Minhas Aventuras</span>
          <% end %>

        <% end %>

      </nav>
  </div>

  <div class="border-t border-[#1e2646] pt-4 flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <div class="h-9 w-9 rounded-full bg-slate-700 flex items-center justify-center text-white font-semibold text-sm">
        <%= current_user.username.to_s.first.upcase rescue "M" %>
      </div>
      <div class="flex flex-col">
        <span class="text-sm font-semibold text-white truncate max-w-[120px]"><%= current_user.username %></span>
        <span class="text-xs text-slate-500">
          <%= current_user.master? ? "Mestre" : "Jogador" %>
        </span>
      </div>
    </div>

    <%= button_to destroy_user_session_path, method: :delete, class: "text-slate-500 hover:text-red-400 transition-colors cursor-pointer", title: "Sair" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
    <% end %>
  </div>
</aside>
