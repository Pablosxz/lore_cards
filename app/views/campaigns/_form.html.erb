<%= form_with(model: campaign, class: "contents", data: { controller: "ai-improve", ai_improve_url_value: ai_improve_text_path }) do |form| %>
  <% if campaign.errors.any? %>
    <div id="error_explanation" class="bg-red-950/60 border border-red-500/40 text-red-400 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= t('.errors_header', count: campaign.errors.count) %></h2>

      <ul class="list-disc ml-6">
        <% campaign.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name, class: "block text-sm font-medium text-white" %>
    <%= form.text_field :name, class: ["block bg-[#11162d] text-white placeholder-slate-500 rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-[#1e2646] focus:border-violet-500 focus:outline-none": campaign.errors[:name].none?, "border-red-500 focus:border-red-500 focus:outline-none": campaign.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <div class="flex items-center justify-between mb-2">
      <%= form.label :base_story, class: "block text-sm font-medium text-white" %>
      <button type="button"
              data-ai-improve-target="button"
              data-action="click->ai-improve#improve"
              class="inline-flex items-center gap-1.5 bg-violet-600 hover:bg-violet-700 disabled:opacity-50 disabled:cursor-not-allowed text-white text-xs px-3 py-1.5 rounded-md transition-colors font-medium">
        <svg data-ai-improve-target="spinner" class="hidden w-3 h-3 animate-spin" viewBox="0 0 24 24" fill="none">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
        </svg>
        <span data-label>Melhorar com IA</span>
      </button>
    </div>
    <%= form.text_area :base_story, rows: 4,
        data: { ai_improve_target: "textarea" },
        class: ["block bg-[#11162d] text-white placeholder-slate-500 rounded-md border outline-none px-3 py-2 w-full", {"border-[#1e2646] focus:border-violet-500 focus:outline-none": campaign.errors[:base_story].none?, "border-red-500 focus:border-red-500 focus:outline-none": campaign.errors[:base_story].any?}] %>
    <p data-ai-improve-target="error" class="hidden text-red-400 text-xs mt-1"></p>
  </div>

  <div class="flex items-center gap-3 mt-2">
    <% if local_assigns[:back_path] %>
      <%= link_to local_assigns[:back_label].presence || t('back'), local_assigns[:back_path], class: "rounded-md px-3.5 py-2.5 bg-slate-700 hover:bg-slate-600 text-slate-100 inline-block font-medium transition-colors" %>
    <% end %>
    <%= form.submit class: "rounded-md px-3.5 py-2.5 bg-violet-600 hover:bg-violet-700 text-white inline-block font-semibold cursor-pointer transition-colors" %>
  </div>
<% end %>
