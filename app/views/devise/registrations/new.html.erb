<div class="flex min-h-screen">

  <%# Left: illustration %>
  <div class="hidden lg:flex w-1/2 items-center justify-center bg-[#0f1424]">
    <%= image_tag "image-cadastro.png", class: "w-full h-full object-cover", alt: "Lore Cards" %>
  </div>

  <%# Right: form %>
  <div class="flex flex-1 items-center justify-center px-8 py-12 bg-[#0f1424]">
    <div class="w-full max-w-sm space-y-6">

      <div class="space-y-2">
        <h1 class="text-3xl font-bold text-white">Bem-Vindo, Mestre!</h1>
        <p class="text-sm text-slate-400">
          Seu próximo grande arco narrativo começa aqui. Seus monstros e itens esperam por você.
        </p>
      </div>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="space-y-4">

          <div class="space-y-1">
            <%= render_label name: "user_username", label: "Nome do usuário", class: "text-slate-200" %>
            <%= render_input type: :text,
                             name: "user[username]",
                             id: "user_username",
                             value: resource.username,
                             placeholder: "mestre_supremo",
                             required: true,
                             autofocus: true,
                             autocomplete: "username",
                             class: "bg-[#1a2035] border-[#2a3354] text-white placeholder:text-slate-500 focus-visible:ring-violet-500" %>
          </div>

          <div class="space-y-1">
            <%= render_label name: "user_email", label: "E-mail", class: "text-slate-200" %>
            <%= render_input type: :email,
                             name: "user[email]",
                             id: "user_email",
                             value: resource.email,
                             placeholder: "mestre@exemplo.com",
                             required: true,
                             autocomplete: "email",
                             class: "bg-[#1a2035] border-[#2a3354] text-white placeholder:text-slate-500 focus-visible:ring-violet-500" %>
          </div>

          <div class="space-y-1">
            <%= render_label name: "user_password", label: "Senha", class: "text-slate-200" %>
            <%= render_input type: :password,
                             name: "user[password]",
                             id: "user_password",
                             required: true,
                             autocomplete: "new-password",
                             class: "bg-[#1a2035] border-[#2a3354] text-white placeholder:text-slate-500 focus-visible:ring-violet-500" %>
          </div>

          <div class="space-y-4 pt-4 pb-6">

            <div class="space-y-1">
              <h3 class="text-slate-200 text-sm font-semibold">
                Escolha seu destino
              </h3>

              <p class="text-xs text-slate-500">
                Defina como deseja explorar o universo Lore Cards.
              </p>
            </div>

            <div class="grid grid-cols-2 gap-4">

              <%# Jogador %>
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="user[role]"
                  value="player"
                  class="hidden role-option"
                  checked
                >

                <div class="role-card selected-role rounded-xl border border-violet-500 bg-violet-600/20 p-4 transition-all duration-200">

                  <div class="flex items-center justify-between mb-3">
                    <div class="h-10 w-10 rounded-lg bg-violet-500/20 flex items-center justify-center text-lg">
                      🎮
                    </div>

                  </div>

                  <h4 class="text-white font-semibold text-sm">
                    Jogador
                  </h4>

                  <p class="text-xs text-slate-400 mt-1 leading-relaxed">
                    Colecione cartas e participe das campanhas.
                  </p>
                </div>
              </label>

              <%# Mestre %>
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="user[role]"
                  value="master"
                  class="hidden role-option"
                >

                <div class="role-card rounded-xl border border-[#2a3354] bg-[#1a2035] p-4 transition-all duration-200 hover:border-violet-500 hover:bg-[#202847]">

                  <div class="flex items-center justify-between mb-3">
                    <div class="h-10 w-10 rounded-lg bg-violet-500/20 flex items-center justify-center text-lg">
                      🧙
                    </div>

                  </div>

                  <h4 class="text-white font-semibold text-sm">
                    Mestre
                  </h4>

                  <p class="text-xs text-slate-400 mt-1 leading-relaxed">
                    Crie campanhas, inimigos e aventuras épicas.
                  </p>
                </div>
              </label>

            </div>
          </div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const options = document.querySelectorAll(".role-option")

    options.forEach((option) => {
      option.addEventListener("change", () => {

        document.querySelectorAll(".role-card").forEach((card) => {
          card.classList.remove(
            "selected-role",
            "border-violet-500",
            "bg-violet-600/20",
            "ring-2",
            "ring-violet-500"
          )

          card.classList.add(
            "border-[#2a3354]",
            "bg-[#1a2035]"
          )
        })

        document.querySelectorAll(".selected-badge").forEach((badge) => {
          badge.classList.add("hidden")
        })

        const selectedCard = option.nextElementSibling
        const selectedBadge = selectedCard.querySelector(".selected-badge")

        selectedCard.classList.add(
          "selected-role",
          "border-violet-500",
          "bg-violet-600/20",
          "ring-2",
          "ring-violet-500"
        )

        selectedBadge.classList.remove("hidden")
      })
    })
  })
</script>
          
          
          <%= button_tag type: "submit",
                class: "w-full mt-2 inline-flex items-center justify-center rounded-md bg-violet-600 hover:bg-violet-700 text-white h-10 px-4 py-2 text-sm font-semibold transition-colors cursor-pointer" do %>
            Cadastrar-se
          <% end %>

        </div>
      <% end %>

      <%- if devise_mapping.confirmable? && resource_name == :user %>
      <% end %>

      <p class="text-center text-sm text-slate-400">
        Já possui uma conta?
        <%= link_to "Entrar", new_session_path(resource_name), class: "font-semibold text-white underline-offset-4 hover:underline" %>
      </p>

    </div>
  </div>

</div>
