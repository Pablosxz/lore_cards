    <!-- Barra de busca superior -->
    <div class="mb-8">
      <%= form_with url: cards_path, method: :get, class: "relative w-full max-w-lg", data: { turbo_frame: "cards_grid", turbo_action: "advance" } do |f| %>
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </span>
        
        <!-- O 'oninput' faz com que o formulário seja enviado a cada letra digitada -->
        <%= f.text_field :query, value: params[:query], placeholder: "Buscar...", oninput: "this.form.requestSubmit()", class: "w-full bg-[#11162d] border border-[#1e2646] rounded-md pl-10 pr-4 py-1.5 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-violet-500" %>
      <% end %>
    </div>

    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold text-white tracking-tight">Minhas Cartas</h1>
      <%= link_to "Adicionar Nova Carta", new_card_path, data: { turbo_frame: "card_modal" }, class: "inline-flex items-center justify-center rounded-md bg-violet-600 hover:bg-violet-700 text-white h-10 px-4 py-2 text-sm font-semibold transition-colors shadow-lg shadow-violet-600/10" %>
    </div>

    <turbo-frame id="cards_grid">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% if @cards.any? %>
          <% @cards.each do |card| %>
            
            <div class="h-[420px] w-full [perspective:1000px] group cursor-pointer" onclick="if(!event.target.closest('.no-flip')) this.querySelector('.flipper').classList.toggle('[transform:rotateY(180deg)]')">
              
              <div class="flipper relative w-full h-full transition-transform duration-700 [transform-style:preserve-3d]">
                
                <div class="absolute inset-0 bg-[#0a0d1a] border-2 border-[#1e2646] rounded-xl p-3 flex flex-col items-center group-hover:border-violet-500/50 transition-colors [backface-visibility:hidden]">
                  
                  <div class="absolute top-2 right-2 z-20 opacity-0 group-hover:opacity-100 transition-all flex space-x-2 no-flip">
                    <%= link_to edit_card_path(card), data: { turbo_frame: "card_modal" }, class: "p-1.5 bg-blue-500/10 text-blue-500 hover:bg-blue-500 hover:text-white rounded-md title='Editar carta' inline-block" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                    <% end %>

                    <%= button_to card_path(card), method: :delete, data: { turbo_confirm: "Tem certeza que deseja destruir esta carta?" }, class: "p-1.5 bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white rounded-md title='Deletar carta'" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    <% end %>
                  </div>

                  <div class="w-full h-48 bg-[#11162d] border-2 border-[#1e2646] rounded-lg mb-4 flex flex-col items-center justify-center text-slate-500 group-hover:bg-[#151b36] group-hover:border-[#2a3354] transition-all mt-4 overflow-hidden">
                    <% if card.image_url.present? %>
                      <img src="<%= card.image_url %>" class="w-full h-full object-cover">
                    <% else %>
                      <svg class="w-8 h-8 mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      <span class="text-xs font-semibold uppercase tracking-wider opacity-60">Sem Imagem</span>
                    <% end %>
                  </div>

                  <h3 class="text-white font-bold text-lg text-center w-full truncate" title="<%= card.name %>">
                    <%= card.name %>
                  </h3>
                  <p class="text-slate-400 text-xs mb-4">
                    <%= card.monster? ? "Monstro" : "Item" %>
                  </p>

                  <% if card.monster? %>
                    <div class="w-full grid grid-cols-2 gap-x-2 gap-y-1 text-[10px]">
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Vida</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.health || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Inteligência</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.intelligence || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Força</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.strength || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Físico</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.physical || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Agilidade</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.agility || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Mental</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.mental || 0 %></span></div>
                    </div>
                  <% elsif card.item? %>
                    <div class="w-full grid grid-cols-2 gap-x-2 gap-y-1 text-[10px]">
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Peso</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.weight || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Bônus</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.active_bonus.presence || "-" %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Dano</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.damage || 0 %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Consumível</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.consumable ? "Sim" : "Não" %></span></div>
                      <div class="flex items-center justify-between"><span class="text-white font-semibold">Raridade</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.rarity.presence || "-" %></span></div>
                    </div>
                  <% end %>
                </div>

                <div class="absolute inset-0 bg-[#e2e8f0] rounded-xl p-6 flex flex-col justify-center items-center text-center [backface-visibility:hidden] [transform:rotateY(180deg)] shadow-xl border-2 border-[#cbd5e1]">
                  <h4 class="text-black font-bold mb-4 text-sm uppercase tracking-wider">Descrição</h4>
                  <p class="text-slate-800 text-xs leading-relaxed overflow-y-auto">
                    <%= card.description.presence || "Nenhuma descrição detalhada foi forjada para esta entidade." %>
                  </p>
                </div>

              </div>
            </div>
          <% end %>
        <% else %>
          <div class="col-span-full border-2 border-dashed border-[#1e2646] rounded-xl p-12 text-center">
            <p class="text-slate-400 text-sm">Nenhuma carta forjada ainda. Clique em "Adicionar Nova Carta" para começar!</p>
          </div>
        <% end %>
      </div>
    </turbo-frame>

<turbo-frame id="card_modal"></turbo-frame>
