<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Lore Cards" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-background text-foreground min-h-screen">
    <% if notice %>
      <div class="fixed top-4 right-4 z-50 rounded-md border border-green-500/40 bg-green-500/10 px-4 py-3 text-sm text-green-400" role="alert">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-4 right-4 z-50 rounded-md border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-400" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <main class="min-h-screen">
      <%= yield %>
    </main>

    <!-- Modal Customizado do Turbo Confirm -->
    <div id="turbo-confirm-dialog" class="hidden fixed inset-0 bg-black/80 z-[100] flex items-center justify-center backdrop-blur-sm">
      <div class="bg-[#11162d] border border-[#1e2646] rounded-xl p-6 max-w-sm w-full mx-4 shadow-2xl transform transition-all">
        <h3 class="text-lg font-bold text-white mb-2">Confirmação</h3>
        <p id="turbo-confirm-message" class="text-sm text-slate-300 mb-6"></p>
        <div class="flex justify-end space-x-3">
          <button id="turbo-confirm-cancel" class="px-4 py-2 text-sm font-medium text-slate-300 hover:text-white transition-colors cursor-pointer">Cancelar</button>
          <button id="turbo-confirm-accept" class="px-4 py-2 rounded-md bg-red-600 hover:bg-red-700 text-white text-sm font-semibold transition-colors cursor-pointer">Confirmar</button>
        </div>
      </div>
    </div>
  </body>
</html>
