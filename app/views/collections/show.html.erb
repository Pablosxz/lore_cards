<% content_for :title, @collection.name %>

<%# Flash notice %>
<% if notice.present? %>
  <div class="mb-6">
    <p class="py-2 px-4 bg-green-950/60 border border-green-500/40 text-green-400 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  </div>
<% end %>

<%# Header %>
<div class="mb-8 flex items-start justify-between gap-4">
  <div class="flex items-center gap-4">
    <%= link_to collections_path, class: "text-slate-400 hover:text-white transition-colors mt-1 flex-shrink-0" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <div>
      <h1 class="text-3xl font-bold text-white tracking-tight"><%= @collection.name %></h1>
      <% if @collection.artistic_style.present? %>
        <p class="text-slate-400 text-sm mt-1"><%= @collection.artistic_style %></p>
      <% end %>
    </div>
  </div>
  <div class="flex items-center gap-3 flex-shrink-0">
    <%= link_to edit_collection_path(@collection), data: { turbo_frame: "collection_modal" },
        class: "inline-flex items-center gap-2 rounded-md px-3.5 py-2 bg-slate-700 hover:bg-slate-600 text-slate-100 text-sm font-medium transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
      </svg>
      Editar
    <% end %>
    <%= button_to collection_path(@collection), method: :delete,
        data: { turbo_confirm: "Tem certeza que deseja excluir esta coleção?" },
        class: "inline-flex items-center gap-2 rounded-md px-3.5 py-2 bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white text-sm font-medium transition-colors cursor-pointer" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Excluir
    <% end %>
  </div>
</div>

<% if @collection.image_url.present? %>
  <div class="mb-8 rounded-xl overflow-hidden border border-[#1e2646] bg-[#0a0d1a]">
    <img src="<%= @collection.image_url %>" alt="Imagem da coleção" class="w-full h-64 object-cover">
  </div>
<% end %>

<%# Ações: nova carta e vincular existente %>
<div class="mb-8 flex items-center gap-3">
  <%= link_to new_card_path(collection_id: @collection.id), data: { turbo_frame: "card_modal" },
      class: "inline-flex items-center gap-2 rounded-md bg-violet-600 hover:bg-violet-700 text-white h-10 px-4 text-sm font-semibold transition-colors shadow-lg shadow-violet-600/10" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Forjar Nova Carta
  <% end %>
  <% if @available_cards.any? %>
    <label for="toggle-vincular" class="inline-flex items-center gap-2 rounded-md bg-[#1e2548] hover:bg-[#2a3354] text-slate-300 h-10 px-4 text-sm font-medium transition-colors cursor-pointer">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      Vincular Carta Existente
    </label>
  <% end %>
</div>

<%# Painel: vincular carta existente (toggle com checkbox) %>
<% if @available_cards.any? %>
  <input type="checkbox" id="toggle-vincular" class="hidden peer/vincular">
  <div class="hidden peer-checked/vincular:block mb-10 bg-[#0a0d1a] border border-[#1e2646] rounded-xl p-6">
    <h2 class="text-lg font-semibold text-white mb-4">Vincular Carta Existente</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
      <% @available_cards.each do |card| %>
        <div class="flex items-center justify-between bg-[#11162d] border border-[#1e2646] rounded-lg px-4 py-3 gap-3">
          <div class="min-w-0">
            <p class="text-white text-sm font-medium truncate"><%= card.name %></p>
            <p class="text-slate-500 text-xs"><%= card.monster? ? "Monstro" : "Item" %></p>
          </div>
          <%= button_to add_card_collection_path(@collection), method: :post,
              params: { card_id: card.id },
              class: "flex-shrink-0 p-1.5 bg-violet-600/20 text-violet-400 hover:bg-violet-600 hover:text-white rounded-md transition-colors cursor-pointer" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Grid de cartas na coleção %>
<div class="mb-4 flex items-center justify-between">
  <h2 class="text-xl font-semibold text-white">
    Cartas
    <span class="ml-2 text-sm font-normal text-slate-400">(<%= @cards_in_collection.count %>)</span>
  </h2>
</div>

<% if @cards_in_collection.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% @cards_in_collection.each do |card| %>
      <div class="h-[420px] w-full [perspective:1000px] group cursor-pointer"
           onclick="if(!event.target.closest('.no-flip')) this.querySelector('.flipper').classList.toggle('[transform:rotateY(180deg)]')">
        <div class="flipper relative w-full h-full transition-transform duration-700 [transform-style:preserve-3d]">

          <%# Frente %>
          <div class="absolute inset-0 bg-[#0a0d1a] border-2 border-[#1e2646] rounded-xl p-3 flex flex-col items-center group-hover:border-violet-500/50 transition-colors [backface-visibility:hidden]">

            <div class="absolute top-2 right-2 z-20 opacity-0 group-hover:opacity-100 transition-all flex space-x-2 no-flip">
              <%= link_to edit_card_path(card), data: { turbo_frame: "card_modal" },
                  class: "p-1.5 bg-blue-500/10 text-blue-500 hover:bg-blue-500 hover:text-white rounded-md inline-block" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                </svg>
              <% end %>
              <%= button_to remove_card_collection_path(@collection), method: :delete,
                  params: { card_id: card.id },
                  data: { turbo_confirm: "Remover esta carta da coleção?" },
                  class: "p-1.5 bg-orange-500/10 text-orange-400 hover:bg-orange-500 hover:text-white rounded-md" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
              <% end %>
              <%= button_to card_path(card), method: :delete,
                  data: { turbo_confirm: "Tem certeza que deseja destruir esta carta?" },
                  class: "p-1.5 bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white rounded-md" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              <% end %>
            </div>

            <div class="w-full h-48 bg-[#11162d] border-2 border-dashed border-[#1e2646] rounded-lg mb-4 flex flex-col items-center justify-center text-slate-500 transition-all mt-4">
              <svg class="w-8 h-8 mb-2 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="text-xs font-semibold uppercase tracking-wider opacity-60">Sem Imagem</span>
            </div>

            <h3 class="text-white font-bold text-lg text-center w-full truncate"><%= card.name %></h3>
            <p class="text-slate-400 text-xs mb-4"><%= card.monster? ? "Monstro" : "Item" %></p>

            <% if card.monster? %>
              <div class="w-full grid grid-cols-2 gap-x-2 gap-y-1 text-[10px]">
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Vida</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.health || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Inteligência</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.intelligence || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Força</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.strength || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Físico</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.physical || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Agilidade</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.agility || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Mental</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.mental || 0 %></span></div>
              </div>
            <% elsif card.item? %>
              <div class="w-full grid grid-cols-2 gap-x-2 gap-y-1 text-[10px]">
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Peso</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.weight || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Bônus</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.active_bonus.presence || "-" %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Dano</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.damage || 0 %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Consumível</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.consumable ? "Sim" : "Não" %></span></div>
                <div class="flex items-center justify-between"><span class="text-white font-semibold">Raridade</span><span class="bg-[#1e2646] text-slate-300 px-2 py-0.5 rounded-sm"><%= card.rarity.presence || "-" %></span></div>
              </div>
            <% end %>
          </div>

          <%# Verso %>
          <div class="absolute inset-0 bg-[#e2e8f0] rounded-xl p-6 flex flex-col justify-center items-center text-center [backface-visibility:hidden] [transform:rotateY(180deg)] shadow-xl border-2 border-[#cbd5e1]">
            <h4 class="text-black font-bold mb-4 text-sm uppercase tracking-wider">Descrição</h4>
            <p class="text-slate-800 text-xs leading-relaxed overflow-y-auto">
              <%= card.description.presence || "Nenhuma descrição detalhada foi forjada para esta entidade." %>
            </p>
          </div>

        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="border-2 border-dashed border-[#1e2646] rounded-xl p-16 text-center">
    <p class="text-slate-400 text-sm mb-4">Nenhuma carta nesta coleção ainda.</p>
    <%= link_to new_card_path(collection_id: @collection.id), data: { turbo_frame: "card_modal" },
        class: "inline-flex items-center gap-2 rounded-md bg-violet-600 hover:bg-violet-700 text-white px-4 py-2 text-sm font-semibold transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Forjar a primeira carta
    <% end %>
  </div>
<% end %>

<turbo-frame id="card_modal"></turbo-frame>
<turbo-frame id="collection_modal"></turbo-frame>
